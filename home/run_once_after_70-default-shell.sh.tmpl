{{ template "bash-header" . }}

shell_path="$(command -v zsh || true)"
[[ -n "$shell_path" ]] || { log_warn "zsh is not installed; skipping default shell update"; exit 0; }

grep -Fxq "$shell_path" /etc/shells || { log_warn "$shell_path is not listed in /etc/shells; add it manually to change the default shell"; exit 0; }

[[ "${SHELL:-}" != "$shell_path" ]] || { log_info "Default shell already $shell_path"; exit 0; }

if chsh -s "$shell_path" "$(id -un)"; then
  log_info "Default shell changed to $shell_path"
else
  log_warn "Failed to change default shell; run 'chsh -s $shell_path' manually"
fi
