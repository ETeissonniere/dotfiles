#!/usr/bin/env bash
set -euo pipefail

KEY_PATH="$HOME/.ssh/id_ed25519"

mkdir -p "$HOME/.ssh"
chmod 700 "$HOME/.ssh"

if [[ -f "$KEY_PATH" ]]; then
  echo "==> SSH key already exists at $KEY_PATH"
  exit 0
fi

ssh-keygen -t ed25519 -f "$KEY_PATH" -N "" -C "$(whoami)@$(hostname)"
echo "==> Generated ed25519 key at $KEY_PATH"
echo
echo "    To register this key on GitHub, run:"
echo "      gh auth login -h github.com -p ssh -s admin:public_key -s admin:ssh_signing_key"
echo "      {{ .chezmoi.workingTree }}/scripts/ssh/register_github_key.sh"
