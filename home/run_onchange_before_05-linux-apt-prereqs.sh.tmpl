{{- if ne .chezmoi.os "darwin" -}}
{{ template "bash-header" . }}

command -v apt-get >/dev/null 2>&1 || { log_warn "apt-get not available; skipping"; exit 0; }

log_info "Ensuring Linux prereqs (build-essential curl git zsh)"
sudo apt-get update
sudo apt-get install -y build-essential curl git zsh
{{- end }}
